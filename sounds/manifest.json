    { "rid": "knight_place_2", "cat": "place", "piece": "N", "file": "knight/knight_place_2.mp3", "name": "Springer Platzieren 2" },
    { "rid": "knight_place_3", "cat": "place", "piece": "N", "file": "knight/knight_place_3.mp3", "name": "Springer Platzieren 3" },

    { "rid": "rook_pickup_1", "cat": "pickup", "piece": "R", "file": "rook/rook_pickup_1.mp3", "name": "Turm Aufheben 1" },
    { "rid": "rook_place_1", "cat": "place", "piece": "R", "file": "rook/rook_place_1.mp3", "name": "Turm Platzieren 1" },
    { "rid": "rook_place_2", "cat": "place", "piece": "R", "file": "rook/rook_place_2.mp3", "name": "Turm Platzieren 2" }
